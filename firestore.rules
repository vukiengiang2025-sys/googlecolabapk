rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }

    function isVerifiedUser() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    // --- Validation Blueprints ---

    function isValidTask(data) {
      return data.keys().hasAll(['id', 'name', 'status', 'ownerId', 'createdAt']) &&
             data.keys().size() <= 15 && 
             data.id is string && data.id.size() <= 64 &&
             data.name is string && data.name.size() <= 200 &&
             data.status is string && data.status.size() <= 32 &&
             data.ownerId == request.auth.uid &&
             (data.get('requirements', null) == null || (
                data.requirements.vram is number && data.requirements.vram >= 0 &&
                data.requirements.priority in ['KHẨN_CẤP', 'CAO', 'TRUNG_BÌNH', 'THẤP']
             ));
    }

    function isValidLog(data) {
      return data.keys().hasAll(['timestamp', 'level', 'msg', 'ownerId']) &&
             data.keys().size() <= 7 &&
             data.msg is string && data.msg.size() <= 2000 &&
             data.level is string &&
             data.ownerId == request.auth.uid;
    }

    function isValidSnippet(data) {
      return data.keys().hasAll(['id', 'title', 'code', 'ownerId', 'createdAt']) &&
             data.id is string && data.id.size() <= 128 &&
             data.title is string && data.title.size() <= 200 &&
             data.code is string && data.code.size() <= 100000 &&
             data.ownerId == request.auth.uid;
    }

    // --- Collection Matches ---

    match /tasks/{taskId} {
      allow get: if isOwner(existing().ownerId);
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      
      allow create: if isVerifiedUser() && 
                    isValidId(taskId) && 
                    isValidTask(incoming()) && 
                    incoming().createdAt == request.time;
      
      allow update: if isVerifiedUser() && 
                    isValidTask(incoming()) && 
                    isOwner(existing().ownerId) &&
                    existing().status != 'THÀNH_CÔNG' &&
                    existing().status != 'LỖI' &&
                    (
                      // Action: Execute
                      (incoming().diff(existing()).affectedKeys().hasOnly(['status', 'executor', 'metrics', 'waitTicks'])) ||
                      // Action: Edit
                      (incoming().diff(existing()).affectedKeys().hasOnly(['name', 'requirements']))
                    ) &&
                    incoming().createdAt == existing().createdAt &&
                    incoming().ownerId == existing().ownerId;

      allow delete: if isOwner(existing().ownerId);
    }

    match /logs/{logId} {
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      
      allow create: if isVerifiedUser() && 
                    isValidId(logId) && 
                    isValidLog(incoming()) && 
                    incoming().timestamp == request.time;
      
      allow read, update, delete: if isOwner(existing().ownerId);
    }

    match /library/{snippetId} {
      allow get, list: if isSignedIn();
      
      allow create: if isVerifiedUser() && 
                    isValidId(snippetId) && 
                    isValidSnippet(incoming()) &&
                    incoming().createdAt == request.time;
      
      allow update: if isVerifiedUser() && 
                    isOwner(existing().ownerId) &&
                    isValidSnippet(incoming()) &&
                    incoming().ownerId == existing().ownerId &&
                    incoming().createdAt == existing().createdAt &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'code', 'type']);
      
      allow delete: if isOwner(existing().ownerId);
    }
  }
}
