{
  "entities": {
    "Task": {
      "title": "AI System Task",
      "description": "A scheduled or running AI workload in the Elite OS system.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "requirements": {
          "type": "object",
          "properties": {
            "vram": { "type": "number" },
            "priority": { "type": "string", "enum": ["KHẨN_CẤP", "CAO", "TRUNG_BÌNH", "THẤP"] },
            "latency": { "type": "string", "enum": ["THỜI_GIAN_THỰC", "LÔ"] }
          }
        },
        "status": { "type": "string" },
        "executor": { "type": "string" },
        "estCost": { "type": "string" },
        "retries": { "type": "number" },
        "waitTicks": { "type": "number" },
        "cost": { "type": "number" },
        "metrics": {
          "type": "object",
          "properties": {
            "throughput": { "type": "string" },
            "nodeId": { "type": "string" },
            "startTime": { "type": "number" },
            "tokens": { "type": "number" }
          }
        },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "status", "ownerId", "createdAt"]
    },
    "Log": {
      "title": "System Log",
      "description": "Logs generated by the AI OS kernel and brain.",
      "type": "object",
      "properties": {
        "timestamp": { "type": "string", "format": "date-time" },
        "level": { "type": "string" },
        "msg": { "type": "string" },
        "executor": { "type": "string" },
        "ownerId": { "type": "string" }
      },
      "required": ["timestamp", "level", "msg", "ownerId"]
    },
    "Snippet": {
      "title": "Elite AI Snippet",
      "description": "Highly optimized AI code snippets stored in the library.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string" },
        "code": { "type": "string" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "code", "ownerId"]
    }
  },
  "firestore": {
    "/tasks/{taskId}": {
      "schema": "Task",
      "description": "Active and completed AI workloads."
    },
    "/logs/{logId}": {
      "schema": "Log",
      "description": "Immutable system event logs."
    },
    "/library/{snippetId}": {
      "schema": "Snippet",
      "description": "User-saved and system default code snippets."
    }
  }
}
